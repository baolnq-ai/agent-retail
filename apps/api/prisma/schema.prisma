generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String   @id @default(cuid())
  name         String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  sessions     UserSession[]
  carts        Cart[]
  chatThreads  ChatThread[]
  preferences  UserPreference[]
  interactions UserInteractionEvent[]
  memoryTurns  MemoryTurn[]
  memoryEvents MemoryEvent[]
  memoryItems  MemoryItem[]
  memorySummaries MemorySummary[]
  memoryPreferences MemoryPreference[]
  memoryBehaviorSignals MemoryBehaviorSignal[]
  memoryAgentIndexes MemoryAgentIndex[]
  searchAgentInteractions SearchAgentInteraction[]
  searchAgentMemory SearchAgentMemory[]
}

model UserSession {
  id        String   @id @default(cuid())
  tokenHash String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model Product {
  id          String   @id
  title       String
  brand       String
  category    String
  price       Int
  currency    String
  inventory   Int
  attributes  Json
  description String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  cartItems    CartItem[]
  interactions UserInteractionEvent[]
  memoryBehaviorSignals MemoryBehaviorSignal[]
  searchDocument ProductSearchDocument?
  embeddings ProductEmbedding[]
}

model KnowledgeDocument {
  id         String   @id
  type       String
  title      String
  content    String
  trustLevel String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Cart {
  id         String   @id
  userId     String?
  version    Int      @default(1)
  status     String   @default("active")
  subtotal   Int      @default(0)
  grandTotal Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user   User?      @relation(fields: [userId], references: [id], onDelete: SetNull)
  items  CartItem[]
  orders Order[]

  @@index([userId])
}

model CartEvent {
  id                String   @id @default(cuid())
  cartId            String
  userId            String?
  requestId         String
  idempotencyKey    String?
  type              String
  productId         String?
  quantityBefore    Int?
  quantityAfter     Int?
  cartVersionBefore Int?
  cartVersionAfter  Int?
  subtotalBefore    Int?
  subtotalAfter     Int?
  actorType         String
  actorAgent        String?
  toolName          String
  sourceMessage     String?
  metadata          Json?
  createdAt         DateTime @default(now())

  @@index([cartId, createdAt])
  @@index([userId, createdAt])
  @@index([requestId])
  @@index([idempotencyKey])
  @@index([productId])
}

model CartAgentMemory {
  id            String   @id @default(cuid())
  userId        String
  cartId        String?
  tier          String
  key           String
  value         Json
  summary       String?
  tokenEstimate Int      @default(0)
  eventCount    Int      @default(0)
  lastEventAt   DateTime?
  expiresAt     DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([userId, tier, updatedAt])
  @@index([cartId, tier, updatedAt])
  @@unique([userId, tier, key])
}

model CartAgentInteraction {
  id                 String    @id @default(cuid())
  userId             String
  cartId             String?
  requestId          String
  leadGoal           String
  normalizedGoal     String
  privatePlan        Json
  toolResultsSummary Json
  facts              Json
  issues             Json
  agentMessage       String
  leadInstruction    String
  status             String
  createdAt          DateTime  @default(now())
  summarizedAt       DateTime?

  @@index([userId, createdAt])
  @@index([cartId, createdAt])
  @@index([requestId])
}

model PendingCartAction {
  id               String   @id @default(cuid())
  userId           String
  cartId           String
  requestId        String
  status           String
  operations       Json
  reason           String
  confirmationText String
  expiresAt        DateTime
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([userId, status, expiresAt])
  @@index([cartId, status])
  @@index([requestId])
}

model ProductSearchDocument {
  id                 String   @id @default(cuid())
  productId          String   @unique
  locale             String   @default("vi-VN")
  searchText         String
  normalizedTitle    String
  normalizedBrand    String
  normalizedCategory String
  attributeText      String
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([normalizedTitle])
  @@index([normalizedBrand])
  @@index([normalizedCategory])
}

model ProductEmbedding {
  id          String   @id @default(cuid())
  productId   String
  model       String
  vector      Json
  contentHash String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, model])
}

model PromptSetting {
  key       String   @id
  label     String
  owner     String
  description String
  content   String
  source    String   @default("default")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SearchAgentInteraction {
  id                  String   @id @default(cuid())
  userId              String?
  requestId           String
  query               String
  normalizedQuery     String
  filters             Json
  usedLanes           Json
  candidateProductIds Json
  selectedProductIds  Json
  facts               Json
  issues              Json
  status              String
  createdAt           DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([requestId])
}

model SearchAgentMemory {
  id            String   @id @default(cuid())
  userId        String
  tier          String
  key           String
  value         Json
  summary       String?
  tokenEstimate Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, tier, updatedAt])
  @@unique([userId, tier, key])
}

model AgentTask {
  id               String   @id @default(cuid())
  requestId        String   @unique
  userId           String?
  cartId           String?
  originalMessage  String
  normalizedGoal   String
  status           String
  budget           Json
  hypotheses       Json
  evidence         Json
  decisions        Json
  evaluatorVerdict Json?
  finalContract    Json?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  completedAt      DateTime?

  events AgentTaskEvent[]

  @@index([userId, createdAt])
  @@index([cartId, createdAt])
  @@index([status, createdAt])
}

model AgentTaskEvent {
  id          String   @id @default(cuid())
  taskId      String
  requestId   String
  agent       String
  stage       String
  status      String
  summary     String
  inputRefs   Json
  outputRefs  Json
  evidence    Json
  toolCall    Json?
  decision    Json?
  durationMs  Int?
  createdAt   DateTime @default(now())

  task AgentTask @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId, createdAt])
  @@index([requestId, createdAt])
  @@index([agent, createdAt])
  @@index([status, createdAt])
}

model CartItem {
  id        String   @id @default(cuid())
  cartId    String
  productId String
  quantity  Int
  unitPrice Int
  lineTotal Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  cart    Cart    @relation(fields: [cartId], references: [id])
  product Product @relation(fields: [productId], references: [id])

  @@unique([cartId, productId])
}

model Order {
  id        String   @id @default(cuid())
  cartId    String
  status    String
  total     Int
  items     Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  cart Cart @relation(fields: [cartId], references: [id])
  payments PaymentIntent[]
}

model PaymentIntent {
  id         String   @id @default(cuid())
  orderId    String
  provider   String
  status     String
  amount     Int
  paymentUrl String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  order Order @relation(fields: [orderId], references: [id])
}

model IdempotencyKey {
  scope        String
  key          String
  responseJson Json
  createdAt    DateTime @default(now())

  @@id([scope, key])
}

model ChatThread {
  id        String   @id @default(cuid())
  userId    String?
  cartId    String?
  title     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user     User?         @relation(fields: [userId], references: [id], onDelete: SetNull)
  messages ChatMessage[]

  @@index([userId])
  @@index([cartId])
}

model ChatMessage {
  id        String   @id @default(cuid())
  threadId  String
  role      String
  content   String
  metadata  Json?
  createdAt DateTime @default(now())

  thread ChatThread @relation(fields: [threadId], references: [id], onDelete: Cascade)

  @@index([threadId])
}

model UserPreference {
  id        String   @id @default(cuid())
  userId    String
  key       String
  value     Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, key])
}

model UserInteractionEvent {
  id        String   @id @default(cuid())
  userId    String?
  productId String?
  type      String
  metadata  Json?
  createdAt DateTime @default(now())

  user    User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  product Product? @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([productId])
  @@index([type])
}

model MemoryTurn {
  id        String   @id @default(cuid())
  userId    String?
  threadId  String?
  requestId String
  role      String
  content   String
  metadata  Json?
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([threadId, createdAt])
  @@index([requestId])
  @@index([role])
}

model MemoryEvent {
  id          String   @id @default(cuid())
  userId      String?
  requestId   String?
  sourceAgent String?
  type        String
  subjectType String?
  subjectId   String?
  payload     Json
  confidence  Float    @default(0.7)
  createdAt   DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId, type, createdAt])
  @@index([requestId])
  @@index([sourceAgent, createdAt])
  @@index([subjectType, subjectId])
}

model MemoryItem {
  id            String    @id @default(cuid())
  userId        String
  tier          String
  key           String
  value         Json
  summary       String?
  sourceRefs    Json
  confidence    Float     @default(0.7)
  tokenEstimate Int       @default(0)
  expiresAt     DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, tier, updatedAt])
  @@index([userId, expiresAt])
  @@unique([userId, tier, key])
}

model MemorySummary {
  id            String   @id @default(cuid())
  userId        String
  scope         String
  sourceAgent   String?
  sourceRefIds  Json
  summary       String
  facts         Json
  confidence    Float    @default(0.7)
  tokenEstimate Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, scope, updatedAt])
  @@index([sourceAgent, updatedAt])
}

model MemoryPreference {
  id          String   @id @default(cuid())
  userId      String
  key         String
  value       Json
  confidence  Float    @default(0.7)
  sourceRefs  Json
  decayPolicy Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, updatedAt])
  @@unique([userId, key])
}

model MemoryBehaviorSignal {
  id          String   @id @default(cuid())
  userId      String?
  productId   String?
  category    String?
  brand       String?
  type        String
  weight      Float    @default(1)
  sourceAgent String?
  metadata    Json?
  createdAt   DateTime @default(now())

  user    User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  product Product? @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@index([userId, type, createdAt])
  @@index([productId, type, createdAt])
  @@index([category, type, createdAt])
  @@index([brand, type, createdAt])
}

model MemoryAgentIndex {
  id          String   @id @default(cuid())
  userId      String?
  sourceAgent String
  sourceTable String
  sourceId    String
  summary     String
  tags        Json
  productIds  Json?
  cartId      String?
  confidence  Float    @default(0.7)
  createdAt   DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId, sourceAgent, createdAt])
  @@index([sourceTable, sourceId])
  @@index([cartId, createdAt])
}
