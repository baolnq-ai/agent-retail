{
  "name": "@retail-agent/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/main.ts",
    "start": "node dist/main.js",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:seed": "tsx prisma/seed.ts",
    "test": "corepack pnpm build && node --test tests/*.test.mjs",
    "test:runtime": "corepack pnpm build && node tests/runtime-health.mjs && node tests/runtime-auth.mjs && node tests/runtime-user-memory.mjs && node tests/runtime-model-gateway.mjs && node tests/runtime-catalog-knowledge.mjs && node tests/runtime-commerce.mjs && node tests/runtime-agent-chat.mjs && node tests/runtime-agent-chat-stream.mjs && node tests/runtime-cors.mjs",
    "test:runtime:cart-agent": "corepack pnpm build && node tests/runtime-cart-agent-mutation-writer.mjs && node tests/runtime-cart-agent-state.mjs && node tests/runtime-cart-agent-pending-flow.mjs",
    "test:runtime:cart-agent:100": "corepack pnpm build && node tests/runtime-cart-agent-real-request-100.mjs",
    "test:runtime:storage-memory-agent": "corepack pnpm build && node tests/runtime-storage-memory-agent.mjs",
    "test:runtime:storage-memory-agent:100": "corepack pnpm build && node tests/runtime-storage-memory-agent-real-request-100.mjs",
    "test:runtime:history-agent:100": "corepack pnpm build && node tests/runtime-history-agent-real-request-100.mjs",
    "test:runtime:search-agent:100": "corepack pnpm build && node tests/runtime-search-agent-real-request-100.mjs",
    "test:runtime:chat-soak:50": "corepack pnpm build && node tests/runtime-agent-chat-soak-50.mjs",
    "test:runtime:chat-soak:100": "corepack pnpm build && node tests/runtime-agent-chat-soak-100.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.9",
    "@nestjs/core": "^11.1.9",
    "@nestjs/platform-fastify": "^11.1.9",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.2.0",
    "@retail-agent/shared": "workspace:*",
    "fastify": "^5.6.2",
    "pg": "^8.20.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2"
  },
  "devDependencies": {
    "prisma": "^7.2.0",
    "tsx": "^4.20.6"
  }
}
