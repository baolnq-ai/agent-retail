# Retail AI Agent configuration
# Copy this file to .env before running setup scripts or Docker Compose.

# Docker Hub image source for the full root docker-compose.yml runtime.
DOCKER_IMAGE_REPO=baonguyen3568/ai-agent-retail
IMAGE_TAG=v0.1.0-20260528
PLATFORMS=linux/amd64,linux/arm64
DOCKER_COMPOSE_PROJECT_NAME=retail_agent_full

API_PORT=6810
WEB_PORT=6800
NGINX_PORT=6820
POSTGRES_PORT=6832
REDIS_PORT=6839
QDRANT_PORT=6833
QDRANT_GRPC_PORT=6834
COMPOSE_PROJECT_NAME=retail_agent_dev

POSTGRES_USER=retail
POSTGRES_PASSWORD=retail_password
POSTGRES_DB=retail_agent
DATABASE_URL=postgresql://retail:retail_password@localhost:6832/retail_agent?schema=public
REDIS_URL=redis://localhost:6839
QDRANT_URL=http://localhost:6833
CORS_ORIGINS=http://127.0.0.1:6800,http://localhost:6800,http://127.0.0.1:6820,http://localhost:6820
NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:6820
NEXT_PUBLIC_SITE_URL=http://127.0.0.1:6820

# Mandatory for real chatbot validation.
CHAT_MODEL_BASE_URL=https://replace-with-your-vllm-gateway.example.invalid
CHAT_MODEL_ID=google/gemma-4-E4B-it
EMBED_RERANK_BASE_URL=https://replace-with-your-embed-rerank-gateway.example.invalid

# Optional runtime controls.
LOG_RETENTION_DAYS=7
LOG_MAX_SIZE_MB=20
RUN_TESTS=0
SKIP_DOCKER=0
SETUP_TERMINAL_MODE=auto
TMUX_SESSION=egnt-retail
RUN_DB_PUSH=1
RUN_DB_SEED=1
WAIT_TIMEOUT_MS=90000
