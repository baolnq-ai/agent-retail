# Retail AI Agent example configuration
# Copy to .env, then replace every placeholder before real chatbot validation.
# Do not commit real tokens, private API URLs, cookies, or credentials.

# Docker Hub image source for the full root docker-compose.yml runtime.
DOCKER_IMAGE_REPO=baonguyen3568/ai-agent-retail
IMAGE_TAG=v0.1.0-20260528
PLATFORMS=linux/amd64,linux/arm64
DOCKER_COMPOSE_PROJECT_NAME=retail_agent_full

# Local runtime ports. Keep every port inside 3100-3150.
API_PORT=3110
WEB_PORT=3100
NGINX_PORT=3120
POSTGRES_PORT=3132
REDIS_PORT=3139
QDRANT_PORT=3133
QDRANT_GRPC_PORT=3134
COMPOSE_PROJECT_NAME=retail_agent_dev

# Local service URLs derived from the ports above.
LOCAL_WEB_URL=http://127.0.0.1:3100
LOCAL_API_URL=http://127.0.0.1:3110
LOCAL_NGINX_URL=http://127.0.0.1:3120
LOCAL_DASHBOARD_URL=http://127.0.0.1:3120/agent-dashboard
LOCAL_API_HEALTH_URL=http://127.0.0.1:3120/health
LOCAL_PRODUCTS_API_URL=http://127.0.0.1:3120/api/v1/products

# Database/cache/vector local connection strings.
POSTGRES_USER=retail
POSTGRES_PASSWORD=retail_password
POSTGRES_DB=retail_agent
DATABASE_URL=postgresql://retail:retail_password@localhost:3132/retail_agent?schema=public
REDIS_URL=redis://localhost:3139
# TTL cache catalog public trong Redis, tính bằng giây. Không cache dữ liệu user/cart/chat bằng khóa chung.
CATALOG_CACHE_TTL_SECONDS=120
QDRANT_URL=http://localhost:3133

# Browser/public URLs.
# For local-only development, keep these on LOCAL_NGINX_URL.
# For Cloudflare tunnel, set TUNNEL_PUBLIC_URL=https://your-name.trycloudflare.com
# and use the same value for NEXT_PUBLIC_API_BASE_URL and NEXT_PUBLIC_SITE_URL.
TUNNEL_PUBLIC_URL=
NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:3120
NEXT_PUBLIC_SITE_URL=http://127.0.0.1:3120
CORS_ORIGINS=http://127.0.0.1:3100,http://localhost:3100,http://127.0.0.1:3120,http://localhost:3120
NEXT_ALLOWED_DEV_ORIGINS=*.trycloudflare.com

# Model gateways. Replace placeholders in your local .env only.
# Keep real vLLM/embed/rerank API URLs out of .env.example.
CHAT_MODEL_BASE_URL=https://replace-with-your-vllm-gateway.example.invalid
CHAT_MODEL_ID=replace-with-your-chat-model-id
EMBED_RERANK_BASE_URL=https://replace-with-your-embed-rerank-gateway.example.invalid

# Optional runtime controls.
LOG_RETENTION_DAYS=7
LOG_MAX_SIZE_MB=20
RUN_TESTS=0
SKIP_DOCKER=0
SETUP_TERMINAL_MODE=auto
TMUX_SESSION=egnt-retail
RUN_DB_PUSH=1
RUN_DB_SEED=1
WAIT_TIMEOUT_MS=90000
