# Retail AI Agent provider source configuration
# Copy this file to .env. Defaults target the local-network model gateways used by this project.

API_PORT=7010
WEB_PORT=7000
NGINX_PORT=7080
POSTGRES_PORT=55432
REDIS_PORT=56379
COMPOSE_PROJECT_NAME=retail_agent_provider

POSTGRES_USER=retail
POSTGRES_PASSWORD=retail_password
POSTGRES_DB=retail_agent
DATABASE_URL=postgresql://retail:retail_password@localhost:55432/retail_agent?schema=public
REDIS_URL=redis://localhost:56379

# Mandatory for real chatbot validation.
CHAT_MODEL_BASE_URL=https://replace-with-your-vllm-gateway.example.invalid
CHAT_MODEL_ID=google/gemma-4-E4B-it
EMBED_RERANK_BASE_URL=https://replace-with-your-embed-rerank-gateway.example.invalid

# Optional runtime controls.
LOG_RETENTION_DAYS=7
LOG_MAX_SIZE_MB=20
RUN_TESTS=0
SKIP_DOCKER=0
