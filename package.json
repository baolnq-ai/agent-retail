{
  "name": "ai-agent-retail",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.20.0",
  "scripts": {
    "build": "corepack pnpm -r build",
    "test": "corepack pnpm -r test",
    "typecheck": "corepack pnpm -r typecheck",
    "prepare:generated": "node scripts/prepare-generated.mjs",
    "validate": "corepack pnpm prepare:generated && corepack pnpm typecheck && corepack pnpm --filter @retail-agent/api test",
    "provider:compose:config": "docker compose -f infra/docker/docker-compose.yml config --quiet",
    "provider:stop": "./stop.sh",
    "provider:clean": "./clean.sh",
    "dev:api": "corepack pnpm --filter @retail-agent/api dev",
    "dev:web": "corepack pnpm --filter @retail-agent/web dev",
    "test:runtime": "corepack pnpm --filter @retail-agent/api test:runtime && corepack pnpm --filter @retail-agent/web test:runtime"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "typescript": "^5.9.3"
  }
}
